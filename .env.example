# Local Clip Studio — Environment Configuration
# Copy this to .env and adjust for your setup.

# Application
LOCALCLIP_STORAGE_PATH=~/.localclip
LOCALCLIP_LOG_LEVEL=INFO
LOCALCLIP_GPU_BACKEND=auto

# Server
LOCALCLIP_HOST=127.0.0.1
LOCALCLIP_PORT=8765
LOCALCLIP_FRONTEND_PORT=5173

# Database
LOCALCLIP_DATABASE_URL=sqlite+aiosqlite:///~/.localclip/config/global.db

# Celery (optional Redis broker)
# LOCALCLIP_CELERY_BROKER_URL=redis://localhost:6379/0
LOCALCLIP_CELERY_BROKER_URL=filesystem://
LOCALCLIP_CELERY_RESULT_BACKEND=db+sqlite:///~/.localclip/config/celery_results.db

# Model Storage
LOCALCLIP_MODELS_PATH=~/.localclip/models

# FFmpeg
# Leave empty to auto-detect from PATH
LOCALCLIP_FFMPEG_PATH=
LOCALCLIP_FFPROBE_PATH=
